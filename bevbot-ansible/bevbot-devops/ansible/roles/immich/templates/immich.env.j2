# ansible/roles/immich/templates/immich.env.j2
# Immich environment — managed by Ansible, do not edit manually.
# Contains secrets — file mode 0600, not committed to git.

DB_PASSWORD={{ immich_db_password }}
DB_USERNAME=immich
DB_DATABASE_NAME=immich
DB_HOSTNAME=immich-db

REDIS_HOSTNAME=immich-redis

JWT_SECRET={{ immich_jwt_secret }}

UPLOAD_LOCATION={{ immich_data_dir }}/upload
THUMBS_LOCATION={{ immich_data_dir }}/thumbs
PROFILE_LOCATION={{ immich_data_dir }}/profile
VIDEO_LOCATION={{ immich_data_dir }}/encoded-video

IMMICH_VERSION={{ immich_version }}

# CPU transcoding only on bevbot1 (GTS 430 unusable for compute)
TRANSCODE_POLICY=disabled
